#!/usr/bin/env python3
"""
gamby - GAMBIT build wrapper with visual status overlay.

Usage:
    gamby make [MAKE_ARGS...]

'gamby make' behaves identically to 'make', but also shows a transparent
image overlay on screen:
  • Green square (happy.png) while the build is running.
  • Red square   (sad.png)   if a build error is detected.

Images live in tools/gamby_images/ next to this script and can be replaced
with any PNG you like (the filenames must stay happy.png / sad.png).

Environment variables:
  GAMBY_IMAGES_DIR        Override the image directory.
  GAMBY_OVERLAY_POSITION  Window corner: bottom-right (default), bottom-left,
                          top-right, top-left.

Setup (add gamby to your PATH):
    export PATH="$PATH:/path/to/gambit/tools"
"""

import os
import pty
import select
import sys
import subprocess
import tempfile
import signal
from pathlib import Path

# ---------------------------------------------------------------------------
# Paths
# ---------------------------------------------------------------------------
SCRIPT_DIR   = Path(__file__).resolve().parent
OVERLAY_PY   = SCRIPT_DIR / "gamby_overlay.py"
_default_img = SCRIPT_DIR / "gamby_images"
IMAGES_DIR   = Path(os.environ.get("GAMBY_IMAGES_DIR", str(_default_img)))


# ---------------------------------------------------------------------------
# Error-line heuristics
# ---------------------------------------------------------------------------
_ERROR_SUBSTRINGS = (
    ": error:",          # GCC/Clang compiler errors
    ": fatal error:",    # GCC/Clang fatal errors
    ": undefined reference",  # linker errors
)
_MAKE_ERROR_MARKER = ("make[", "*** [")  # make error propagation lines


def _is_error_line(line: str) -> bool:
    lo = line.lower()
    for pat in _ERROR_SUBSTRINGS:
        if pat in lo:
            return True
    # "make[N]: *** [target] Error N"
    if _MAKE_ERROR_MARKER[0] in line and _MAKE_ERROR_MARKER[1] in line:
        return True
    # CMake / ninja
    if line.startswith("CMake Error") or line.startswith("FAILED:"):
        return True
    return False


# ---------------------------------------------------------------------------
# State file helpers
# ---------------------------------------------------------------------------
def _write_state(path: str, state: str) -> None:
    try:
        with open(path, "w") as fh:
            fh.write(state)
    except OSError:
        pass


# ---------------------------------------------------------------------------
# Overlay process
# ---------------------------------------------------------------------------
def _start_overlay(state_file: str):
    happy = IMAGES_DIR / "happy.png"
    sad   = IMAGES_DIR / "sad.png"
    if not (happy.exists() and sad.exists()):
        return None

    has_display = bool(
        os.environ.get("DISPLAY") or os.environ.get("WAYLAND_DISPLAY")
    )
    if not has_display:
        return None

    try:
        proc = subprocess.Popen(
            [sys.executable, str(OVERLAY_PY), str(happy), str(sad), state_file],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
        )
        return proc
    except Exception:
        return None


def _stop_overlay(proc, state_file: str) -> None:
    if proc is None:
        return
    _write_state(state_file, "done")
    try:
        proc.wait(timeout=2)
    except subprocess.TimeoutExpired:
        proc.terminate()


# ---------------------------------------------------------------------------
# Build runner
# ---------------------------------------------------------------------------
def _run_make(args: list, state_file: str) -> int:
    """Run make under a PTY so the subprocess sees a real terminal.

    Using a PTY means make and the compiler inherit a TTY file descriptor,
    so GCC/Clang colour diagnostics and make's own progress output are
    preserved exactly as they would be in a normal interactive session.
    stdout and stderr are merged into the single PTY stream (the same way a
    real terminal works) and forwarded to our own stdout.
    """
    cmd = ["make"] + args
    error_signalled = False

    def _on_error():
        nonlocal error_signalled
        if not error_signalled:
            error_signalled = True
            _write_state(state_file, "sad")

    master_fd, slave_fd = pty.openpty()

    try:
        proc = subprocess.Popen(
            cmd,
            stdout=slave_fd,
            stderr=slave_fd,
            close_fds=True,
        )
    except FileNotFoundError:
        os.close(master_fd)
        os.close(slave_fd)
        print("gamby: 'make' not found in PATH", file=sys.stderr)
        return 127

    os.close(slave_fd)  # parent only reads from the master end

    # Incomplete line buffer for cross-chunk error detection.
    tail = b""

    try:
        while True:
            try:
                readable, _, _ = select.select([master_fd], [], [], 0.05)
            except (ValueError, select.error):
                break

            if readable:
                try:
                    chunk = os.read(master_fd, 4096)
                except OSError:
                    # EIO is the normal EOF signal when the slave side closes.
                    break

                if not chunk:
                    break

                sys.stdout.buffer.write(chunk)
                sys.stdout.buffer.flush()

                # Scan for error lines, keeping a partial line across chunks.
                text = (tail + chunk).decode("utf-8", errors="replace")
                *complete, tail_str = text.split("\n")
                tail = tail_str.encode("utf-8")
                for line in complete:
                    if _is_error_line(line):
                        _on_error()

            elif proc.poll() is not None:
                # Drain any last bytes after the process exits.
                try:
                    while True:
                        r, _, _ = select.select([master_fd], [], [], 0)
                        if not r:
                            break
                        chunk = os.read(master_fd, 4096)
                        if not chunk:
                            break
                        sys.stdout.buffer.write(chunk)
                        sys.stdout.buffer.flush()
                        text = (tail + chunk).decode("utf-8", errors="replace")
                        *complete, tail_str = text.split("\n")
                        tail = tail_str.encode("utf-8")
                        for line in complete:
                            if _is_error_line(line):
                                _on_error()
                except OSError:
                    pass
                break

    except KeyboardInterrupt:
        proc.send_signal(signal.SIGINT)
    finally:
        try:
            os.close(master_fd)
        except OSError:
            pass
        proc.wait()

    if tail and _is_error_line(tail.decode("utf-8", errors="replace")):
        _on_error()

    if proc.returncode != 0:
        _on_error()

    return proc.returncode


# ---------------------------------------------------------------------------
# Subcommand: make
# ---------------------------------------------------------------------------
def cmd_make(args: list) -> int:
    state_file = os.path.join(
        tempfile.gettempdir(), f"gamby_state_{os.getpid()}.txt"
    )
    _write_state(state_file, "happy")

    overlay = _start_overlay(state_file)
    try:
        rc = _run_make(args, state_file)
    finally:
        _stop_overlay(overlay, state_file)
        try:
            os.unlink(state_file)
        except OSError:
            pass

    return rc


# ---------------------------------------------------------------------------
# Entry point
# ---------------------------------------------------------------------------
def main() -> None:
    if len(sys.argv) < 2 or sys.argv[1] in ("-h", "--help"):
        print(__doc__)
        sys.exit(0)

    command = sys.argv[1]
    rest    = sys.argv[2:]

    if command == "make":
        sys.exit(cmd_make(rest))
    else:
        print(f"gamby: unknown command '{command}'", file=sys.stderr)
        print("Available commands: make", file=sys.stderr)
        sys.exit(1)


if __name__ == "__main__":
    main()
